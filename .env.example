# GitHub 設定
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxx
# GH_ORG: organization 名または個人アカウント名（owner login）
GH_ORG=your-org-or-username
GH_PROJECT_NUMBER=1
# GH_OWNER_TYPE: organization project の場合は 'org'（省略可・デフォルト）
#                user project（https://github.com/users/<login>/projects/<n>）の場合は 'user'
# GH_OWNER_TYPE=user

# Backlog 設定
BACKLOG_API_KEY=your_backlog_api_key
BACKLOG_SPACE=yourspace
BACKLOG_PROJECT_KEY=PROJ

# dry-run モード（true にすると Backlog への書き込みをスキップしてログのみ出力）
# 初回テスト時は true を推奨。本番同期時に false に変更してください。
DRY_RUN=true

# 処理件数の上限（Draft 除外後の先頭 N 件のみ処理する）
# 初回本番テストでは LIMIT=1 で 1 件だけ試すことを推奨
# 未指定・空にすると全件処理（通常運用時はコメントアウトするか空にする）
# LIMIT=1

# 担当者の強制再同期（一時的な運用・通常は使わない）
# FORCE_ASSIGNEE_SYNC=true にすると、FORCE_SYNC_ITEM_URL に一致する 1 件だけ
# assigneeId を差分判定なしで強制的に update に含める
# 使用後は必ず両方をコメントアウトまたは削除すること
# FORCE_ASSIGNEE_SYNC=true
# FORCE_SYNC_ITEM_URL=https://github.com/<owner>/<repo>/issues/<n>

# Due Date 同期の調査用（一時的・本番では使わない）
# DEBUG_DUE_DATE_SYNC=true
# 省略時は先頭 1 件。特定 Issue のみに絞る場合は GitHub Issue の URL を指定
# DEBUG_DUE_DATE_ITEM_URL=https://github.com/<owner>/<repo>/issues/<n>
